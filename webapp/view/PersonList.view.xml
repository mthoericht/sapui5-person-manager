<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	controllerName="person.app.controller.PersonList"
>
	<Page
		title="{i18n>personsTitle}"
		showNavButton="false"
		busy="{/list/busy}"
	>
		<headerContent>
			<Label text="{i18n>language}" labelFor="languageSelect" />
			<Select
				id="languageSelect"
				selectedKey="{/currentLanguage}"
				change="onLanguageChange"
				width="9rem"
			>
				<items>
					<core:Item key="de" text="{i18n>languageGerman}" />
					<core:Item key="en" text="{i18n>languageEnglish}" />
				</items>
			</Select>
		</headerContent>
		<content>
			<VBox class="personListContainer sapUiResponsiveMargin sapUiContentPadding">
				<Table
					id="personTable"
					items="{/persons}"
					mode="MultiSelect"
					selectionChange="onSelectionChange"
				>
					<headerToolbar>
						<OverflowToolbar>
							<Title text="{i18n>personsTitle}" level="H1" />
							<ToolbarSpacer />
							<Label text="{i18n>sortBy}" labelFor="sortFieldSelect" />
							<Select
								id="sortFieldSelect"
								selectedKey="{/sortField}"
								change="onSortFieldChange"
								width="10rem"
							>
								<items>
									<core:Item key="firstName" text="{i18n>sortFirstName}" />
									<core:Item key="lastName" text="{i18n>sortLastName}" />
									<core:Item key="email" text="{i18n>sortEmail}" />
								</items>
							</Select>
							<Button
								icon="{= ${/sortDescending} ? 'sap-icon://sort-descending' : 'sap-icon://sort-ascending' }"
								tooltip="{= ${/sortDescending} ? ${i18n>sortDirectionDesc} : ${i18n>sortDirectionAsc} }"
								ariaHasPopup="None"
								press="onSortDirectionToggle"
							/>
							<SearchField
								id="personSearchField"
								class="personSearchField"
								placeholder="{i18n>searchPlaceholder}"
								liveChange="onSearch"
								search="onSearch"
							>
								<layoutData>
									<OverflowToolbarLayoutData
										shrinkable="true"
									/>
								</layoutData>
							</SearchField>
							<Button text="{i18n>create}" type="Emphasized" press="onCreate" />
							<Button
								text="{i18n>delete}"
								type="Negative"
								press="onDelete"
								enabled="{= ${/selectedPersonIds}.length > 0 }"
							/>
						</OverflowToolbar>
					</headerToolbar>
					<columns>
						<Column>
							<Text text="{i18n>firstName}" />
						</Column>
						<Column>
							<Text text="{i18n>lastName}" />
						</Column>
						<Column>
							<Text text="{i18n>email}" />
						</Column>
					</columns>
					<items>
						<ColumnListItem type="Navigation" press="onItemPress">
							<cells>
								<Text text="{firstName}" />
								<Text text="{lastName}" />
								<Text text="{email}" />
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</VBox>
		</content>
	</Page>
</mvc:View>

