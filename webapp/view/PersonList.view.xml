<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	controllerName="person.app.controller.PersonList"
>
	<Page
		title="{i18n>personsTitle}"
		showNavButton="false"
		busy="{/busy}"
	>
		<headerContent>
			<Label text="{i18n>language}" labelFor="languageSelect" />
			<Select
				id="languageSelect"
				selectedKey="{/currentLanguage}"
				change="onLanguageChange"
				width="9rem"
			>
				<items>
					<core:Item key="de" text="{i18n>languageGerman}" />
					<core:Item key="en" text="{i18n>languageEnglish}" />
				</items>
			</Select>
		</headerContent>
		<content>
			<VBox class="personListContainer sapUiResponsiveMargin sapUiContentPadding">
				<Table
					id="personTable"
					items="{/persons}"
					mode="SingleSelectLeft"
					selectionChange="onSelectionChange"
				>
					<headerToolbar>
						<OverflowToolbar>
							<Title text="{i18n>personsTitle}" />
							<ToolbarSpacer />
							<SearchField
								id="personSearchField"
								class="personSearchField"
								placeholder="{i18n>searchPlaceholder}"
								liveChange="onSearch"
								search="onSearch"
							>
								<layoutData>
									<OverflowToolbarLayoutData
										shrinkable="true"
									/>
								</layoutData>
							</SearchField>
							<Button text="{i18n>create}" type="Emphasized" press="onCreate" />
							<Button
								text="{i18n>delete}"
								type="Negative"
								press="onDelete"
								enabled="{= !!${/selectedPersonId} }"
							/>
						</OverflowToolbar>
					</headerToolbar>
					<columns>
						<Column>
							<HBox alignItems="Center" renderType="Bare">
								<Text text="{i18n>firstName}" />
								<Button
									type="Transparent"
									icon="{= ${/sortField} === 'firstName' ? (${/sortDescending} ? 'sap-icon://sort-descending' : 'sap-icon://sort-ascending') : 'sap-icon://sort' }"
									tooltip="{i18n>sortByFirstName}"
									press="onHeaderSortPress"
								>
									<customData>
										<core:CustomData key="sortField" value="firstName" />
									</customData>
								</Button>
							</HBox>
						</Column>
						<Column>
							<HBox alignItems="Center" renderType="Bare">
								<Text text="{i18n>lastName}" />
								<Button
									type="Transparent"
									icon="{= ${/sortField} === 'lastName' ? (${/sortDescending} ? 'sap-icon://sort-descending' : 'sap-icon://sort-ascending') : 'sap-icon://sort' }"
									tooltip="{i18n>sortByLastName}"
									press="onHeaderSortPress"
								>
									<customData>
										<core:CustomData key="sortField" value="lastName" />
									</customData>
								</Button>
							</HBox>
						</Column>
						<Column>
							<HBox alignItems="Center" renderType="Bare">
								<Text text="{i18n>email}" />
								<Button
									type="Transparent"
									icon="{= ${/sortField} === 'email' ? (${/sortDescending} ? 'sap-icon://sort-descending' : 'sap-icon://sort-ascending') : 'sap-icon://sort' }"
									tooltip="{i18n>sortByEmail}"
									press="onHeaderSortPress"
								>
									<customData>
										<core:CustomData key="sortField" value="email" />
									</customData>
								</Button>
							</HBox>
						</Column>
					</columns>
					<items>
						<ColumnListItem type="Navigation" press="onItemPress">
							<cells>
								<Text text="{firstName}" />
								<Text text="{lastName}" />
								<Text text="{email}" />
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</VBox>
		</content>
	</Page>
</mvc:View>

