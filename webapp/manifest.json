{
  "_version": "1.68.0",
  "sap.app": {
    "id": "person.app",
    "type": "application",
    "title": "Person App",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5 TypeScript",
    "deviceTypes": {
      "desktop": true,
      "phone": true,
      "tablet": true
    },
    "supportedThemes": ["sap_horizon"],
    "contentDensities": {
      "cozy": true,
      "compact": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.125",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.unified": {}
      },
      "theme": "sap_horizon"
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "person.app.i18n.i18n"
        }
      }
    },
    "rootView": {
      "viewName": "person.app.view.App",
      "type": "XML",
      "id": "app"
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "person.app.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "clearTarget": false
      },
      "routes": [
        {
          "pattern": "",
          "name": "list",
          "target": "list"
        },
        {
          "pattern": "person/{id}",
          "name": "detail",
          "target": "detail"
        }
      ],
      "targets": {
        "list": {
          "viewName": "PersonList"
        },
        "detail": {
          "viewName": "PersonDetail"
        }
      }
    }
  }
}
