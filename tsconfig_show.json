{
    "compilerOptions": {
        "target": "es2023",
        "module": "es2022",
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0",
        "skipLibCheck": true,
        "allowJs": true,
        "strict": true,
        "strictPropertyInitialization": false,
        "rootDir": "./webapp",
        "composite": true,
        "noEmit": true,
        "resolvePackageJsonExports": false,
        "resolvePackageJsonImports": false,
        "resolveJsonModule": false,
        "declaration": true,
        "incremental": true
    },
    "files": [
        "./webapp/Component.ts",
        "./webapp/controller/PersonDetail.controller.ts",
        "./webapp/controller/PersonList.controller.ts",
        "./webapp/model/Person.ts",
        "./webapp/model/PersonService.ts"
    ],
    "include": [
        "./webapp/**/*"
    ]
}
