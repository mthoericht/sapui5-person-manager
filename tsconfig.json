{
  "compilerOptions": {
    "target": "es2023",
    "module": "es2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "rootDir": "./webapp",
    "types": ["openui5"],
    "composite": true,
    "noEmit": true
  },
  "include": ["./webapp/**/*"]
}
